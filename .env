# Network preset: "testnet" (Gonka testnet + Sepolia) or "mainnet" (Gonka mainnet
# + Ethereum). Defaults to testnet when unset.
VITE_NETWORK=testnet

# Optional: override the active EVM chain's JSON-RPC URL. A dedicated provider
# (Alchemy/Infura) is recommended for production over the public default.
# VITE_EVM_RPC_URL=https://ethereum-rpc.publicnode.com

# Optional: override the active Gonka host (chain RPC + REST + /v1/bls).
# Testnet default: http://89.169.111.79:8000   Mainnet default: https://node1.gonka.ai:8443
# VITE_GONKA_HOST=
